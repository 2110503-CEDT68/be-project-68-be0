        {
          "name": "Create Reservation - Outside Open Hours (Condition Check)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set time outside open hours (02:00 UTC - before 08:00 open)",
                  "// Use random day 50-200 days ahead to avoid duplicate same-day check on re-run",
                  "const randomDays = 50 + Math.floor(Math.random() * 150);",
                  "const future = new Date();",
                  "future.setDate(future.getDate() + randomDays);",
                  "future.setUTCHours(2, 0, 0, 0);",
                  "pm.environment.set('OUTSIDE_HOURS_DATE', future.toISOString());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function() { pm.response.to.have.status(400); });",
                  "pm.test('Condition - reject outside open hours', function() {",
                  "  pm.expect(pm.response.json().success).to.be.false;",
                  "  pm.expect(pm.response.json().message).to.match(/open from/i);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{TOKEN-U}}", "type": "string" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservation_date\": \"{{OUTSIDE_HOURS_DATE}}\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{URL}}/api/restaurants/{{RESTAURANT_ID}}/reservations",
              "host": ["{{URL}}"],
              "path": [
                "api",
                "restaurants",
                "{{RESTAURANT_ID}}",
                "reservations"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Reservation - Duplicate Same Day (Condition Check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function() { pm.response.to.have.status(400); });",
                  "pm.test('Condition - reject duplicate same day', function() {",
                  "  pm.expect(pm.response.json().success).to.be.false;",
                  "  pm.expect(pm.response.json().message).to.match(/already have a reservation/i);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{TOKEN-U}}", "type": "string" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservation_date\": \"{{RESERVATION_DATE}}\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{URL}}/api/restaurants/{{RESTAURANT_ID}}/reservations",
              "host": ["{{URL}}"],
              "path": [
                "api",
                "restaurants",
                "{{RESTAURANT_ID}}",
                "reservations"
              ]
            }
          },
          "response": []
        }
      ]
