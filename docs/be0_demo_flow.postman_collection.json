    {
      "name": "4 User Create Booking + Check Create Condition",
      "item": [
        {
          "name": "Create Reservation",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set reservation date 3 days from now at 12:00 UTC (within open hours)",
                  "const future = new Date();",
                  "future.setDate(future.getDate() + 3);",
                  "future.setUTCHours(12, 0, 0, 0);",
                  "pm.environment.set('RESERVATION_DATE', future.toISOString());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() { pm.response.to.have.status(201); });",
                  "pm.test('Reservation created', function() {",
                  "  const res = pm.response.json();",
                  "  pm.expect(res.success).to.be.true;",
                  "  pm.expect(res.data._id).to.exist;",
                  "  pm.environment.set('RESERVATION_ID', res.data._id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{TOKEN-U}}", "type": "string" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservation_date\": \"{{RESERVATION_DATE}}\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{URL}}/api/restaurants/{{RESTAURANT_ID}}/reservations",
              "host": ["{{URL}}"],
              "path": [
                "api",
                "restaurants",
                "{{RESTAURANT_ID}}",
                "reservations"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Reservation - No Date (Condition Check)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function() { pm.response.to.have.status(400); });",
                  "pm.test('Condition - reject missing date', function() {",
                  "  pm.expect(pm.response.json().success).to.be.false;",
