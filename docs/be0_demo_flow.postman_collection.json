              "raw": "{{URL}}/api/restaurants/{{RESTAURANT_ID}}/reservations",
              "host": ["{{URL}}"],
              "path": [
                "api",
                "restaurants",
                "{{RESTAURANT_ID}}",
                "reservations"
              ]
            }
          },
          "response": []
        },
